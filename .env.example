# GitHub token (classic or fine-grained with public_repo read)
GITHUB_TOKEN=

# OpenAI API key (for AI-assisted search)
OPENAI_API_KEY=
# Optional model override (default: gpt-4.1-mini)
OPENAI_MODEL=

# Database URL (used by Prisma)
DATABASE_URL=postgresql://user:password@localhost:5432/repo_metrics

# Server port (default 3005)
PORT=3005

# Optional
NODE_ENV=development
